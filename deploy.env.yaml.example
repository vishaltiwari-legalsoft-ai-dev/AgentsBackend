# Cloud Run environment variables.
# Copy to `deploy.env.yaml`, fill in real values, and deploy with:
#   gcloud run deploy agentos-backend --source . --env-vars-file deploy.env.yaml ...
# A YAML file avoids comma-escaping issues that --set-env-vars has.
#
# NOTE: Do NOT set GOOGLE_APPLICATION_CREDENTIALS here — Cloud Run uses the
# attached service account automatically. Do NOT set BRAND_KITS_DIR (ingestion
# is a local-only task; prod reads the data already in Firestore/GCS).

OPENROUTER_API_KEY: "sk-or-v1-..."
OPENROUTER_MODEL: "anthropic/claude-sonnet-4.5"
OPENROUTER_IMAGE_MODEL: "google/gemini-3-pro-image-preview"
OPENROUTER_VISION_MODEL: "openai/gpt-4o-mini"

GCP_PROJECT_ID: "helpful-charmer-498509-v5"
GCS_BUCKET_NAME: "ls_agent_team"
FIRESTORE_DATABASE: "lsbrandkit"

JWT_SECRET: "<your 96-char secret>"
JWT_EXPIRES_MINUTES: "10080"
GOOGLE_CLIENT_ID: "255561670915-...apps.googleusercontent.com"
ADMIN_EMAILS: "vishal.tiwari@Legalsoft.com"

# Set these to your Vercel URL AFTER the frontend is deployed (see steps).
APP_PUBLIC_URL: "https://your-app.vercel.app"
CORS_ORIGINS: "https://your-app.vercel.app"

# Optional — only if using Canva in production:
# CANVA_CLIENT_ID: "..."
# CANVA_CLIENT_SECRET: "..."
# CANVA_REDIRECT_URI: "https://YOUR-BACKEND.run.app/api/canva/callback"
