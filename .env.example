# Copy to `.env` and fill in real values. Never commit `.env`.

# --- Server ---
APP_ENV=development
PORT=8080
# Comma-separated browser origins allowed to call this API (your Vercel URL).
# Comma-separated browser origins. Include every frontend you run locally.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Auth ---
# Generate: python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET=
JWT_EXPIRES_MINUTES=10080
# Google OAuth Web Client ID (same value as the frontend NEXT_PUBLIC_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=
# Comma-separated emails granted the Super Admin panel, e.g. you@company.com
ADMIN_EMAILS=

# --- OpenRouter (agent LLM + image generation) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Reasoning "brain" for the agent (persona, creative decision, master prompt)
OPENROUTER_MODEL=anthropic/claude-opus-4.6
# Fast model for trivial parsing (aspect ratio/brief extraction, URL guess)
OPENROUTER_FAST_MODEL=anthropic/claude-sonnet-4.5
# Premium image-output model. Flux.2 Pro = studio-grade default for ad backgrounds.
# For absolute max quality set: black-forest-labs/flux.2-max
# Other strong options: google/gemini-3-pro-image-preview, openai/gpt-5.4-image-2
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-pro
OPENROUTER_IMAGE_MODEL_HERO=black-forest-labs/flux.2-max
# Vision-capable model used for OCR on uploaded images.
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini

APP_PUBLIC_URL=http://localhost:3000
APP_TITLE=AgentOS

# --- Google Cloud (Firestore + Cloud Storage) ---
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
GCS_BUCKET_NAME=
# Firestore database id (use "(default)" or a named DB like "lsbrandkit").
FIRESTORE_DATABASE=(default)

# --- Canva Connect ---
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
# Note: Canva requires 127.0.0.1 (not "localhost") for local redirect URIs.
CANVA_REDIRECT_URI=http://127.0.0.1:8080/api/canva/callback

# --- Brand asset source (ingestion) ---
BRAND_KITS_DIR=C:\Users\ACER\Desktop\ghi\Data

# --- Brand Reference Library (Google Drive sync) ---
# The shared Drive folder of on-brand reference creatives, synced into the agent's
# reference library via POST /api/ref-library/sync-drive (admin button in the
# Integrations panel). Subfolders map to: Carousel->carousel, Story->social_story,
# "LS Gradients"->brand_gradient, "Newsletter Graphics"->newsletter.
# Prereqs: enable the Google Drive API on the project, and share this folder with
# the service account (GOOGLE_APPLICATION_CREDENTIALS / Cloud Run identity).
GD_DRIVE_FOLDER_ID=1-Uc5z2Rx5TlA3lRFBxDHDIpslVl3r_pG
GD_DRIVE_BRAND_NAME=Legal Soft
# Where the synced assets + index live. On Cloud Run set a writable path (e.g.
# /tmp/reference_library); locally defaults to Data/_reference_mock when unset.
# GD_REFERENCE_DIR=
